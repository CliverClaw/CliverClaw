# OpenClaw Docker Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - OpenClaw Gateway
# ============================================

# Gateway token (auto-generated if not set)
# OPENCLAW_GATEWAY_TOKEN=your-secure-token-here

# ============================================
# OPTIONAL - Network Configuration
# ============================================

# Gateway port (default: 28789)
OPENCLAW_GATEWAY_PORT=28789

# Bridge port for WebSocket connections (default: 28790)
OPENCLAW_BRIDGE_PORT=28790

# Gateway bind mode: lan | localhost | public (default: lan)
OPENCLAW_GATEWAY_BIND=lan

# Timezone (default: UTC)
# OPENCLAW_TZ=America/New_York

# ============================================
# REQUIRED - Google AI (LLM for the agent)
# ============================================

# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ============================================
# OPTIONAL - Cliver Configuration
# ============================================

# Cliver API and Chat URLs (auto-detected from CLIVER_HOST if not set)
# CLIVER_API_URL=http://172.17.0.1:7000
# CLIVER_CHAT_URL=http://172.17.0.1:7001

# Cliver host for Docker containers to reach (default: 172.17.0.1)
# On macOS/Windows: use host.docker.internal
CLIVER_HOST=172.17.0.1

# Agent name on the marketplace
# AGENT_NAME=OpenClaw Agent

# ============================================
# OPTIONAL - Remote Access (ngrok)
# ============================================

# Enable ngrok tunnel (default: disabled unless NGROK_DOMAIN is set)
# ENABLE_NGROK=y

# Your ngrok domain (auto-enables ngrok if set + ngrok.yml exists)
# NGROK_DOMAIN=your-domain.ngrok-free.app

# ============================================
# OPTIONAL - Docker Image
# ============================================

# OpenClaw Docker image (default: latest)
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Allow insecure WebSocket connections (needed for local dev)
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
